# ── TrustMart AI Agent .env ───────────────────────────────

# Claude API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Agent wallet private key (a SEPARATE wallet for the AI agent)
# Fund it with a small amount of testnet KITE for gas + attestation fees
AGENT_PRIVATE_KEY=0xAGENT_WALLET_PRIVATE_KEY

# Kite Chain RPC
KITE_RPC_URL=https://rpc-testnet.gokite.ai/

# Contract addresses (from deploy script output)
ATTESTATION_REGISTRY_ADDRESS=
ESCROW_ORDER_ADDRESS=
PRODUCT_REGISTRY_ADDRESS=
DISPUTE_RESOLVER_ADDRESS=

# Agent server port
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
