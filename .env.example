# ── TrustMart Root .env ──────────────────────────────────
# Copy this to .env and fill in your values

# Deployer wallet private key (the wallet that deploys contracts)
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# AI Agent wallet private key (SEPARATE wallet — fund with small KITE)
AGENT_PRIVATE_KEY=0xYOUR_AGENT_WALLET_PRIVATE_KEY

# Fee receiver address (your wallet to receive platform fees)
FEE_RECEIVER_ADDRESS=

# Kite Chain RPC (pre-filled)
KITE_RPC_URL=https://rpc-testnet.gokite.ai/

# KiteScan API key (optional, for contract verification)
KITESCAN_API_KEY=

REPORT_GAS=true
