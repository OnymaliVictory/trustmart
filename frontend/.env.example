# ── TrustMart Frontend .env.local ────────────────────────
# Copy to .env.local — addresses auto-loaded from deployedAddresses.json
# but you can override here

NEXT_PUBLIC_PRODUCT_REGISTRY_ADDRESS=
NEXT_PUBLIC_ESCROW_ORDER_ADDRESS=
NEXT_PUBLIC_DISPUTE_RESOLVER_ADDRESS=
NEXT_PUBLIC_REPUTATION_SYSTEM_ADDRESS=
NEXT_PUBLIC_ATTESTATION_REGISTRY_ADDRESS=

# Kite Chain (pre-filled)
NEXT_PUBLIC_CHAIN_ID=2368
NEXT_PUBLIC_RPC_URL=https://rpc-testnet.gokite.ai/
NEXT_PUBLIC_EXPLORER_URL=https://testnet.kitescan.ai
NEXT_PUBLIC_CURRENCY_SYMBOL=KITE

# AI Agent URL (running locally or hosted)
NEXT_PUBLIC_AGENT_URL=http://localhost:3001
